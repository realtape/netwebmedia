{
  "_doc": "Sourcing config for the NWM OS design-partner sourcing pipeline. Read by /source-agency-leads. Edit query templates, geo filters, scoring weights, and exclusions here — the slash command stays generic.",
  "_version": 1,
  "_updated": "2026-05-28",

  "verticals": {
    "law_firms": {
      "display": "Law firm marketing",
      "queries": [
        "\"law firm marketing agency\" small boutique founder fractional CMO services",
        "\"law firm marketing\" \"GoHighLevel\" OR \"HubSpot partner\" agency founder",
        "\"personal injury marketing agency\" OR \"criminal defense marketing\" small US founder"
      ],
      "bonus_keywords": ["personal injury", "estate planning", "family law", "intake automation", "AEO for lawyers"],
      "vertical_strength": "high"
    },
    "real_estate": {
      "display": "Real estate marketing",
      "queries": [
        "\"real estate marketing agency\" small founder OR owner GoHighLevel United States retainer clients",
        "\"realtor marketing\" \"AEO\" OR \"HubSpot partner\" small agency",
        "\"mortgage marketing agency\" OR \"property management marketing\" boutique founder"
      ],
      "bonus_keywords": ["MLS", "brokerage", "listing automation", "geographic farming"],
      "vertical_strength": "high"
    },
    "home_services": {
      "display": "Home services marketing (HVAC/plumbing/electrical)",
      "queries": [
        "\"home services marketing agency\" small founder boutique HVAC OR plumbing OR contractor clients",
        "\"contractor marketing\" \"AI SEO\" OR GHL small agency founder",
        "\"HVAC marketing agency\" OR \"plumbing marketing\" boutique founder US"
      ],
      "bonus_keywords": ["HVAC", "plumbing", "roofing", "electrical", "ServiceTitan", "Housecall Pro"],
      "vertical_strength": "high"
    },
    "tourism": {
      "display": "Hospitality + tourism marketing",
      "queries": [
        "\"hospitality marketing agency\" boutique founder hotel OR resort OR vacation rental",
        "\"hotel marketing agency\" small founder direct bookings",
        "\"tour operator marketing\" OR \"vacation rental marketing\" agency boutique"
      ],
      "bonus_keywords": ["OTA", "direct bookings", "STR", "vacation rental", "booking.com alternative"],
      "vertical_strength": "medium"
    },
    "restaurants": {
      "display": "Restaurant + cafe marketing",
      "queries": [
        "\"restaurant marketing agency\" small founder local",
        "\"hospitality marketing agency\" restaurant cafe owner",
        "\"food service marketing agency\" boutique founder"
      ],
      "bonus_keywords": ["Toast", "Square", "OpenTable", "menu engineering", "reputation management"],
      "vertical_strength": "medium"
    },
    "health": {
      "display": "Healthcare + medical practice marketing",
      "queries": [
        "\"medical marketing agency\" boutique founder clinic dental veterinary",
        "\"healthcare marketing agency\" small HIPAA founder",
        "\"dental marketing agency\" OR \"chiropractic marketing\" founder small"
      ],
      "bonus_keywords": ["HIPAA", "patient acquisition", "clinic", "veterinary", "dental"],
      "vertical_strength": "high"
    },
    "beauty": {
      "display": "Beauty + spa + salon marketing",
      "queries": [
        "\"med spa marketing agency\" founder boutique",
        "\"salon marketing agency\" small founder",
        "\"beauty industry marketing\" agency boutique founder"
      ],
      "bonus_keywords": ["med spa", "salon", "barber", "booksy", "fresha"],
      "vertical_strength": "medium"
    },
    "automotive": {
      "display": "Auto dealer + repair shop marketing",
      "queries": [
        "\"auto dealer marketing agency\" founder boutique",
        "\"auto repair marketing\" agency small founder",
        "\"automotive marketing agency\" boutique founder"
      ],
      "bonus_keywords": ["DMS", "dealer", "service drive", "Repair Shop Pro"],
      "vertical_strength": "medium"
    },
    "education": {
      "display": "School + tutor + language school marketing",
      "queries": [
        "\"education marketing agency\" tutor school founder boutique",
        "\"private school marketing\" agency founder",
        "\"online course marketing\" agency boutique founder"
      ],
      "bonus_keywords": ["enrollment", "admissions", "K-12", "tutoring", "language school"],
      "vertical_strength": "low"
    },
    "events_weddings": {
      "display": "Wedding + event marketing",
      "queries": [
        "\"wedding marketing agency\" founder boutique",
        "\"event marketing agency\" small founder weddings",
        "\"event venue marketing\" agency boutique"
      ],
      "bonus_keywords": ["The Knot", "WeddingWire", "venue booking", "event planner"],
      "vertical_strength": "low"
    },
    "financial_services": {
      "display": "Financial advisor + accountant marketing",
      "queries": [
        "\"financial advisor marketing agency\" founder compliance FINRA",
        "\"accounting firm marketing\" agency small founder",
        "\"CPA marketing\" agency boutique founder"
      ],
      "bonus_keywords": ["FINRA", "SEC", "RIA", "fiduciary", "client acquisition"],
      "vertical_strength": "medium"
    },
    "wine_agriculture": {
      "display": "Wine + winery + agriculture marketing",
      "queries": [
        "\"winery marketing agency\" founder boutique",
        "\"wine industry marketing\" agency small founder",
        "\"farm marketing agency\" OR \"agritourism marketing\" founder"
      ],
      "bonus_keywords": ["DTC", "wine club", "tasting room", "vineyard"],
      "vertical_strength": "low"
    },
    "local_specialist": {
      "display": "Boutique + gym + niche local",
      "queries": [
        "\"gym marketing agency\" founder boutique fitness",
        "\"boutique retail marketing\" agency small founder",
        "\"local business marketing agency\" small founder Main Street"
      ],
      "bonus_keywords": ["membership growth", "retention", "MindBody"],
      "vertical_strength": "low"
    },
    "smb": {
      "display": "Generalist SMB marketing (catch-all)",
      "queries": [
        "\"small marketing agency\" \"we use GoHighLevel\" founder OR owner 10 employees",
        "\"AEO agency\" OR \"answer engine optimization\" marketing agency United States founder small",
        "\"fractional CMO\" marketing agency boutique founder small business clients"
      ],
      "bonus_keywords": ["fractional CMO", "GoHighLevel", "HubSpot Partner", "AEO"],
      "vertical_strength": "high"
    }
  },

  "geos": {
    "us": {
      "display": "United States",
      "query_suffix": "United States",
      "country_code": "US",
      "priority": 1
    },
    "us_southeast": {
      "display": "US Southeast (FL, GA, NC, SC, TN, AL)",
      "query_suffix": "Florida OR Georgia OR Tennessee OR Carolinas",
      "country_code": "US",
      "priority": 2
    },
    "us_west": {
      "display": "US West (CA, OR, WA, NV, AZ)",
      "query_suffix": "California OR Oregon OR Washington OR Nevada OR Arizona",
      "country_code": "US",
      "priority": 2
    },
    "us_texas": {
      "display": "Texas",
      "query_suffix": "Texas",
      "country_code": "US",
      "priority": 3
    },
    "miami_bilingual": {
      "display": "Miami / South Florida bilingual EN-ES",
      "query_suffix": "Miami bilingual Spanish English Hispanic market",
      "country_code": "US",
      "priority": 2
    },
    "chile": {
      "display": "Chile (NWM home market)",
      "query_suffix": "Chile Santiago agencia marketing digital",
      "country_code": "CL",
      "priority": 3
    },
    "mexico": {
      "display": "Mexico",
      "query_suffix": "Mexico CDMX Guadalajara Monterrey agencia",
      "country_code": "MX",
      "priority": 3
    },
    "spain": {
      "display": "Spain",
      "query_suffix": "España Madrid Barcelona agencia marketing",
      "country_code": "ES",
      "priority": 3
    }
  },

  "scoring": {
    "_doc": "Per-candidate score = sum(weights). Tier thresholds map raw score → Tier 1/2/3.",
    "weights": {
      "verified_founder_name": 15,
      "verified_email_visible": 10,
      "verified_phone_visible": 10,
      "explicit_aeo_mention": 12,
      "hubspot_partner_badge": 10,
      "gohighlevel_agency_mention": 10,
      "fractional_cmo_offering": 8,
      "boutique_under_50_confirmed": 10,
      "boutique_under_15_confirmed": 15,
      "matches_nwm_vertical_high": 12,
      "matches_nwm_vertical_medium": 8,
      "matches_nwm_vertical_low": 4,
      "bilingual_en_es_signal": 8,
      "us_based_primary_geo": 8,
      "founded_2010_or_later": 4
    },
    "tier_thresholds": {
      "tier_1_min": 55,
      "tier_2_min": 35,
      "tier_3_min": 18
    }
  },

  "exclusions": {
    "_doc": "Domain or name patterns that disqualify a candidate. Applied after scrape, before scoring.",
    "domain_patterns": [
      "linkedin.com",
      "facebook.com",
      "instagram.com",
      "twitter.com",
      "x.com",
      "tiktok.com",
      "clutch.co",
      "designrush.com",
      "g2.com",
      "trustpilot.com",
      "yelp.com",
      "upwork.com",
      "fiverr.com"
    ],
    "agency_type_disqualifiers": [
      "talent marketplace",
      "freelancer platform",
      "directory site",
      "SaaS product (not agency)",
      "in-house team",
      "enterprise consulting >50 staff",
      "pure brand identity studio (no retainers)",
      "link building only"
    ],
    "agency_name_substrings": [
      "Marketing.com",
      "Best Agency",
      "Top 10"
    ]
  },

  "scrape_schema": {
    "type": "object",
    "properties": {
      "agency_name": {"type": "string"},
      "founder_name": {"type": "string"},
      "founder_title": {"type": "string"},
      "email": {"type": "string"},
      "phone": {"type": "string"},
      "location": {"type": "string"},
      "team_size_signal": {"type": "string"},
      "key_verticals": {"type": "array", "items": {"type": "string"}},
      "year_founded": {"type": "string"},
      "is_boutique_under_50": {"type": "boolean"},
      "is_boutique_under_15": {"type": "boolean"},
      "uses_gohighlevel": {"type": "boolean"},
      "is_hubspot_partner": {"type": "boolean"},
      "mentions_aeo": {"type": "boolean"},
      "offers_fractional_cmo": {"type": "boolean"},
      "agency_type": {"type": "string", "description": "boutique-agency, large-agency, SaaS, talent-marketplace, directory, unclear"}
    }
  },

  "outputs": {
    "wave_dir": "plans/nwm-os/waves/",
    "wave_filename_pattern": "wave-{date}-{vertical}-{geo}.md",
    "master_list_path": "plans/nwm-os/warm-list.md",
    "dedupe_by": "domain",
    "max_candidates_per_wave": 12
  },

  "weekly_rotation": {
    "_doc": "Vertical rotation for the weekly scheduled run. /source-agency-leads --auto picks next in line.",
    "order": [
      "law_firms",
      "real_estate",
      "home_services",
      "smb",
      "health",
      "tourism",
      "restaurants",
      "beauty",
      "financial_services",
      "automotive",
      "wine_agriculture",
      "education",
      "events_weddings",
      "local_specialist"
    ],
    "default_geo": "us"
  }
}
