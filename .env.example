# NetWebMedia environment template
# Copy to .env at repo root and fill in. .env is gitignored — never commit.
# Loaded by api-php/lib/env.php via getenv() / $_ENV.

# ── Error monitoring (Sentry) ────────────────────────────────────────────
SENTRY_DSN=                       # https://xxx@oXXX.ingest.sentry.io/XXX (browser + php share if same project, else split)
SENTRY_ENV=production             # production | staging | dev
NWM_RELEASE=nwm@1.0.0             # bumped by deploy workflow

# ── Transactional email (Resend) ─────────────────────────────────────────
RESEND_API_KEY=                   # re_xxx — https://resend.com/api-keys
RESEND_FROM=admin@netwebmedia.com # must match a verified Resend domain

# ── AI providers ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                # sk-ant-... — primary LLM (Claude)
HEYGEN_API_KEY=                   # avatar video generation
VAPI_API_KEY=                     # voice-agent platform

# ── Meta / WhatsApp ──────────────────────────────────────────────────────
META_APP_SECRET=                  # used by whatsapp webhook signature verify (fail-closed)
WHATSAPP_TOKEN=                   # permanent system-user token
META_PIXEL_ID=                    # 15-16 digit Pixel ID, surfaced to front-end

# ── Analytics ────────────────────────────────────────────────────────────
GA4_MEASUREMENT_ID=G-V71R6PD7C0   # public, but kept here so templates can inject

# ── Ops webhooks ─────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=                # incoming-webhook for uptime + incident alerts
