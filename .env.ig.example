# Instagram credentials for scripts/ig_publish/ig_publish.py
#
# 1. Copy this file to .env.ig (same directory, no .example suffix)
# 2. Fill in the values below
# 3. .env.ig is gitignored — NEVER commit credentials
#
# This is your IG account login (same as the mobile app). The script uses
# instagrapi (unofficial mobile API) to publish without going through Meta's
# Graph API web flow. Posting limits: ~5 posts/day per account to avoid bot
# flags; space posts 4+ hours apart.

IG_USERNAME=netwebmedia
IG_PASSWORD=replace_me_with_real_password

# Optional: if you've enabled SMS or app-based 2FA on @netwebmedia, the script
# will prompt for the 6-digit code interactively on first login. After that,
# the session is saved to ~/.nwm-ig-session.json and reused without 2FA.
