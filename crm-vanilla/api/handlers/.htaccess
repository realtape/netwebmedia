# Block all direct public web access to CRM API handler files.
# Handlers are filesystem-included by ../index.php (the query-string router),
# which enforces the auth / CSRF / payment / tenancy gates. A direct HTTP
# request to a handler .php bypasses that gate (it just hits an undefined
# router symbol and 500s today) — deny it at the server as defence-in-depth.
# The router's require() is a filesystem include and is unaffected by this.

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
