{
  "name": "netwebmedia-app",
  "version": "0.1.0",
  "private": true,
  "description": "NetWebMedia mobile app — iOS + Android + web. Capacitor wrapper over the existing NWM API.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "sync": "npm run build && cap sync",
    "ios": "npm run sync && cap open ios",
    "android": "npm run sync && cap open android",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.2",
    "@capacitor/browser": "^6.0.4",
    "@capacitor/core": "^6.2.1",
    "@capacitor/haptics": "^6.0.2",
    "@capacitor/keyboard": "^6.0.3",
    "@capacitor/preferences": "^6.0.3",
    "@capacitor/push-notifications": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/android": "^6.2.1",
    "vite": "^5.4.10"
  }
}
