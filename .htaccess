# php -- BEGIN cPanel-generated handler, do not edit
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php74 .php .php7 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

# ── Mobile deep-linking: /.well-known/ files MUST be served as JSON ────
# Apple Universal Links (apple-app-site-association, NO extension) + Android
# App Links (assetlinks.json) are fetched by iOS/Android to verify app↔domain
# association. They must be 200 w/ application/json and NO redirect.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^\.well-known/apple-app-site-association$ - [L,E=AASA:1]
</IfModule>
<IfModule mod_headers.c>
  <FilesMatch "^apple-app-site-association$">
    Header set Content-Type "application/json"
  </FilesMatch>
  <FilesMatch "^assetlinks\.json$">
    Header set Content-Type "application/json"
  </FilesMatch>
</IfModule>

# ── Block sensitive directories from public access ─────────────────────
# robots.txt disallows these, but server-level denial is the hard guarantee.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^\.venv(/|$)              - [F,L]
  RewriteRule ^_deploy(/|$)             - [F,L]
  RewriteRule ^_backup(/|$)             - [F,L]
  RewriteRule ^_cron(/|$)               - [F,L]
  RewriteRule ^backend(/|$)             - [F,L]
  RewriteRule ^api-php(/|$)             - [F,L]
  RewriteRule ^n8n-templates(/|$)       - [F,L]
  RewriteRule ^plans(/|$)               - [F,L]
  RewriteRule ^proposals(/|$)           - [F,L]
  RewriteRule ^deliverables(/|$)        - [F,L]
  RewriteRule ^email-templates(/|$)     - [F,L]
  RewriteRule ^site-upload(/|$)         - [F,L]
  # /guides/ and /lp/ are public marketing content (noindex prevents SEO,
  # but bot + paid ads link to them directly — must be reachable).
</IfModule>

# ── Industry subdomain routing ─────────────────────────────────────────
# Maps 39 industry subdomains to their folders under /industries/.
# Requires ONE cPanel action: create a wildcard subdomain *.netwebmedia.com
# pointing at public_html (the same doc root as netwebmedia.com). All 39
# subdomains below then resolve via these internal rewrites — no per-
# subdomain cPanel entry needed.
#
# NOTE: these are INTERNAL rewrites (no [R] flag), so the browser URL
# stays pretty (e.g. hotels.netwebmedia.com/audit/) while Apache serves
# /industries/hospitality/hotels/audit/index.html under the hood.
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Map clean /unsubscribe (GET + POST for Gmail one-click) to /unsubscribe.php.
  # Must come BEFORE the skip-rules block so it's reachable across all hosts.
  RewriteRule ^unsubscribe/?$ /unsubscribe.php [L,QSA]

  # Skip rewrite if already inside /industries/ or on specific PHP endpoints to prevent loops
  RewriteCond %{REQUEST_URI} ^/industries/ [OR]
  RewriteCond %{REQUEST_URI} ^/audit-submit\.php$ [OR]
  RewriteCond %{REQUEST_URI} ^/unsubscribe\.php$
  RewriteRule .* - [L]

  # ── Parent industry subdomains (10) ──
  RewriteCond %{HTTP_HOST} ^hospitality\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/hospitality/$1 [L]
  RewriteCond %{HTTP_HOST} ^healthcare\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/healthcare/$1 [L]
  RewriteCond %{HTTP_HOST} ^beauty\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/beauty/$1 [L]
  RewriteCond %{HTTP_HOST} ^pro\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/professional-services/$1 [L]
  RewriteCond %{HTTP_HOST} ^realestate\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/real-estate/$1 [L]
  RewriteCond %{HTTP_HOST} ^restaurants\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/restaurants/$1 [L]
  RewriteCond %{HTTP_HOST} ^fitness\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/fitness/$1 [L]
  RewriteCond %{HTTP_HOST} ^ecommerce\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/ecommerce/$1 [L]
  RewriteCond %{HTTP_HOST} ^home\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/home-services/$1 [L]
  RewriteCond %{HTTP_HOST} ^tech\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/tech-saas/$1 [L]

  # ── Hospitality subcategories (3) ──
  RewriteCond %{HTTP_HOST} ^hotels\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/hospitality/hotels/$1 [L]
  RewriteCond %{HTTP_HOST} ^boutique\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/hospitality/boutique/$1 [L]
  RewriteCond %{HTTP_HOST} ^resorts\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/hospitality/resorts/$1 [L]

  # ── Healthcare subcategories (3) ──
  RewriteCond %{HTTP_HOST} ^dental\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/healthcare/dental/$1 [L]
  RewriteCond %{HTTP_HOST} ^vet\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/healthcare/vet/$1 [L]
  RewriteCond %{HTTP_HOST} ^aesthetics\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/healthcare/aesthetics/$1 [L]

  # ── Beauty & Wellness subcategories (3) ──
  RewriteCond %{HTTP_HOST} ^salons\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/beauty/salons/$1 [L]
  RewriteCond %{HTTP_HOST} ^spas\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/beauty/spas/$1 [L]
  RewriteCond %{HTTP_HOST} ^barbershops\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/beauty/barbershops/$1 [L]

  # ── Professional Services subcategories (3) ──
  RewriteCond %{HTTP_HOST} ^legal\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/professional-services/legal/$1 [L]
  RewriteCond %{HTTP_HOST} ^accounting\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/professional-services/accounting/$1 [L]
  RewriteCond %{HTTP_HOST} ^consulting\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/professional-services/consulting/$1 [L]

  # ── Real Estate subcategories (3) ──
  RewriteCond %{HTTP_HOST} ^agents\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/real-estate/agents/$1 [L]
  RewriteCond %{HTTP_HOST} ^brokerages\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/real-estate/brokerages/$1 [L]
  RewriteCond %{HTTP_HOST} ^propertymanagement\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/real-estate/property-management/$1 [L]

  # ── Restaurants & F&B subcategories (2) ──
  RewriteCond %{HTTP_HOST} ^bars\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/restaurants/bars/$1 [L]
  RewriteCond %{HTTP_HOST} ^catering\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/restaurants/catering/$1 [L]

  # ── Fitness & Gyms subcategories (3) ──
  RewriteCond %{HTTP_HOST} ^gyms\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/fitness/gyms/$1 [L]
  RewriteCond %{HTTP_HOST} ^studios\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/fitness/studios/$1 [L]
  RewriteCond %{HTTP_HOST} ^personaltraining\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/fitness/personal-training/$1 [L]

  # ── E-commerce subcategories (3) ──
  RewriteCond %{HTTP_HOST} ^shopify\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/ecommerce/shopify/$1 [L]
  RewriteCond %{HTTP_HOST} ^dtc\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/ecommerce/dtc/$1 [L]
  RewriteCond %{HTTP_HOST} ^marketplace\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/ecommerce/marketplace/$1 [L]

  # ── Home Services subcategories (3) ──
  RewriteCond %{HTTP_HOST} ^contractors\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/home-services/contractors/$1 [L]
  RewriteCond %{HTTP_HOST} ^plumbers\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/home-services/plumbers/$1 [L]
  RewriteCond %{HTTP_HOST} ^landscaping\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/home-services/landscaping/$1 [L]

  # ── Tech & SaaS subcategories (3) ──
  RewriteCond %{HTTP_HOST} ^saas\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/tech-saas/saas/$1 [L]
  RewriteCond %{HTTP_HOST} ^startups\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/tech-saas/startups/$1 [L]
  RewriteCond %{HTTP_HOST} ^agencies\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /industries/tech-saas/agencies/$1 [L]
</IfModule>

# ── /app/* and /crm/* soft-fallback for unshipped feature pages ────────
# Homepage and product pages link to roughly 45 /app/<slug> targets that
# do not exist as files yet. Instead of 404-ing every prospect that clicks
# a product tour card, route every NON-EXISTENT /app/*  or  /crm/*  path to
# the coming-soon waitlist page. Shipped modules (conversations, marketing-
# pipeline, sales-pipeline under /app/, and the real /crm-vanilla/ app
# surface) keep working because the RewriteCond checks for file/dir
# existence first.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^app/.+$ /app/coming-soon.html [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^crm/[^/]+\.html$ /app/coming-soon.html [L]
</IfModule>

# ── URL redirects (301) ────────────────────────────────────────────────
# Clean URLs → canonical .html destinations.
# /qna.html was an old nav link; Q&A now lives at /faq.html.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^qna\.html$    /faq.html       [R=301,L,NC]
  RewriteRule ^contact$      /contact.html   [R=301,L,NC]
  RewriteRule ^services$     /services.html  [R=301,L,NC]
  RewriteRule ^pricing$      /pricing.html   [R=301,L,NC]
  RewriteRule ^blog$         /blog.html      [R=301,L,NC]
  RewriteRule ^about$        /about.html     [R=301,L,NC]
  RewriteRule ^faq$          /faq.html       [R=301,L,NC]
  RewriteRule ^partners$     /partners.html  [R=301,L,NC]
  RewriteRule ^results$      /results.html   [R=301,L,NC]
  RewriteRule ^tutorials$    /tutorials.html [R=301,L,NC]
  RewriteRule ^aeo$          /aeo-agency.html [R=301,L,NC]
  RewriteRule ^aeo-agency$   /aeo-agency.html [R=301,L,NC]
</IfModule>

# ── Security headers ───────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ── GZIP / DEFLATE compression ─────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript application/json
  AddOutputFilterByType DEFLATE application/xml application/rss+xml image/svg+xml
  AddOutputFilterByType DEFLATE font/ttf font/otf font/woff font/woff2 application/vnd.ms-fontobject
</IfModule>

# ── Browser caching ────────────────────────────────────────────────────
# HTML: never cache — always serve fresh so deploys propagate immediately
# CSS/JS: short cache with revalidation — cache-busting (?v=N) controls versions
# Images/fonts: long cache — these rarely change
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                                "access plus 1 month"
  ExpiresByType text/html                       "access plus 0 seconds"
  ExpiresByType text/css                        "access plus 5 minutes"
  ExpiresByType application/javascript          "access plus 5 minutes"
  ExpiresByType application/x-javascript        "access plus 5 minutes"
  ExpiresByType image/jpeg                      "access plus 1 year"
  ExpiresByType image/png                       "access plus 1 year"
  ExpiresByType image/gif                       "access plus 1 year"
  ExpiresByType image/webp                      "access plus 1 year"
  ExpiresByType image/svg+xml                   "access plus 1 year"
  ExpiresByType image/x-icon                    "access plus 1 year"
  ExpiresByType font/woff                       "access plus 1 year"
  ExpiresByType font/woff2                      "access plus 1 year"
  ExpiresByType application/font-woff           "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  # Images & fonts: long immutable cache (filename-versioned so this is safe)
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|woff|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # CSS/JS: short cache, must-revalidate — cache-busting is via ?v=N query string
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
    Header unset Expires
    Header set Expires "0"
  </FilesMatch>
  # HTML: always fresh — deploys must propagate immediately
  <FilesMatch "\.html$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>
