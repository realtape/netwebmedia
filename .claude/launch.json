{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "alerta-comunidad",
      "runtimeExecutable": "node",
      "runtimeArgs": ["community-alert-app/server.js"],
      "port": 3000
    },
    {
      "name": "poker-news",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "poker-news", "-p", "8080", "-c-1"],
      "port": 8080
    },
    {
      "name": "netwebmedia",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", ".", "-p", "8083", "-c-1"],
      "port": 8083
    },
    {
      "name": "icelocator",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "../icelocator/public", "-l", "3456", "--no-clipboard"],
      "port": 3456
    },
    {
      "name": "crm",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "crm", "--", "-p", "3001"],
      "port": 3001
    },
    {
      "name": "crm-vanilla",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "crm-vanilla", "-p", "8081", "-c-1"],
      "port": 8081
    },
    {
      "name": "templates-site",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "templates-site", "-p", "8082", "-c-1"],
      "port": 8082
    },
    {
      "name": "nwm-mobile",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "mobile"],
      "port": 5173
    }
  ]
}
