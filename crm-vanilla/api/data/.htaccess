# Block all public web access to crm-vanilla/api/data/.
# Files here (kb.json, runtime config) contain internal facts and must never be readable from the web.
# Loaded server-side by PHP only.

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
