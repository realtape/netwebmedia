RewriteEngine On
RewriteBase /api/

# Redirect direct /api-php/ access → canonical /api/ (per CLAUDE.md invariant).
# THE_REQUEST contains the raw request line (e.g. "GET /api-php/foo HTTP/1.1").
# %1 captures the path after /api-php/ so we preserve the rest of the URL.
# This per-directory .htaccess overrides the root rewrite (Apache default
# behavior — child .htaccess replaces parent RewriteRules unless
# RewriteOptions Inherit is set), so the redirect MUST live here, not in /.
RewriteCond %{THE_REQUEST} \s/api-php/(.*?)\sHTTP
RewriteRule ^ /api/%1 [R=301,L]

# CORS — allowlist only; never echo arbitrary Origin
<IfModule mod_headers.c>
  SetEnvIf Origin "^https://(netwebmedia\.com|www\.netwebmedia\.com|app\.netwebmedia\.com)$" CORS_OK=1
  Header always set Access-Control-Allow-Origin "https://netwebmedia.com" env=CORS_OK
  Header always set Access-Control-Allow-Credentials "true" env=CORS_OK
  Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS" env=CORS_OK
  Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Auth-Token" env=CORS_OK
</IfModule>

# Do not expose lib/ or routes/ or migrate.php directly
RewriteRule ^(lib|routes)/ - [F,L]

# Everything else → index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [L,QSA]
