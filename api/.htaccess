# NetWebMedia /api/ bridge — force every request through index.php
# so stale files in /public_html/api/ cannot be served directly.
# index.php forwards to /public_html/api-php/index.php (the canonical router).

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Exempt the CRM SPA: app.netwebmedia.com/api/* is a *separate* CRM API
  # served from /crm-vanilla/api/. The root host-based rewrite in
  # /public_html/.htaccess remaps app.* → /crm-vanilla/$1, but Apache's
  # directory-descent processes /api/.htaccess BEFORE the host rewrite
  # gets a chance to fire on the second internal pass — so we'd otherwise
  # bridge straight to api-php/ and the CRM auth endpoint breaks. This
  # rule restores the CRM's own /api/ tree for that one host.
  RewriteCond %{HTTP_HOST} ^app\.netwebmedia\.com$ [NC]
  RewriteRule ^(.*)$ /crm-vanilla/api/$1 [L]

  # Everything else → index.php (bridge to /api-php/)
  RewriteRule ^.*$ index.php [QSA,L]
</IfModule>

# Deny direct access to *.js files in /api/ (leftover Node.js serverless handlers
# from the Next.js CRM; they are not served by this PHP backend).
<FilesMatch "\.js$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# JSON responses should never be cached at intermediate proxies.
<IfModule mod_headers.c>
  <FilesMatch "\.(php)$">
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
  </FilesMatch>
</IfModule>
